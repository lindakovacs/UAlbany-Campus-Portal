# ⚠️  IMPORTANT: Frontend Configuration
# If you change FRONTEND_PORT, also update in frontend/config.js (FRONTEND_URL line 13)
# Production:
FRONTEND_PORT=3000
FRONTEND_URL=http://localhost:3000
# Development (Live Server):
# FRONTEND_PORT=5500
# FRONTEND_URL=http://127.0.0.1:5500

# Backend Configuration
# ⚠️  IMPORTANT: If you change PORT, update frontend/config.js (BACKEND_PORT line 17)
PORT=3001
NODE_ENV=development

# Database Configuration
DB_HOST=localhost
DB_USER=root
DB_PASSWORD=your_actual_password_here
DB_NAME=ualbany_campus

# JWT Configuration
JWT_SECRET=your_super_secret_key_change_in_production
JWT_EXPIRE=7d

# Gemini AI Configuration (Optional)
# Generate your free API key at: https://ai.google.dev/
# Model: Gemini 2.5 Flash-Lite (1000 free requests/day)
# Example: GEMINI_API_KEY="Your GeminiAI_API_KEY here"
# Leave blank (GEMINI_API_KEY=) to use mock chatbot responses
GEMINI_API_KEY=  ##"Your GeminiAI_API_KEY here"
GEMINI_MODEL=gemini-2.5-flash
