# ⚠️  IMPORTANT: Frontend Configuration
# If you change FRONTEND_PORT, also update in frontend/config.js (FRONTEND_URL line 13)
FRONTEND_PORT=3000
FRONTEND_URL=http://localhost:3000

# Backend Configuration
# ⚠️  IMPORTANT: If you change PORT, update frontend/config.js (BACKEND_PORT line 17)
PORT=3001
NODE_ENV=development

# Database Configuration
DB_HOST=localhost
DB_USER=root
DB_PASSWORD=your_actual_password_here
DB_NAME=ualbany_campus

# JWT Configuration
JWT_SECRET=your_super_secret_key_change_in_production
JWT_EXPIRE=7d
